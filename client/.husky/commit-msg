#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Get commit message
commit_regex='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .{1,50}'

if ! grep -qE "$commit_regex" "$1"; then
    echo "❌ Commit message does not follow conventional format!"
    echo ""
    echo "Expected format: <type>(<scope>): <description>"
    echo ""
    echo "Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
    echo "Example: feat(auth): add password reset functionality"
    echo "Example: fix(ui): resolve button alignment issue"
    echo ""
    echo "Learn more: https://www.conventionalcommits.org/"
    exit 1
fi

# Check message length
if [ ${#1} -gt 72 ]; then
    echo "❌ Commit message is too long! Maximum 72 characters allowed."
    exit 1
fi

echo "✅ Commit message format is valid!"
